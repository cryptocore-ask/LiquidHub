# =============================================================================
# Liquid Hub — Standard Pool Configuration (UNI-ARB-WETH-USDC)
# =============================================================================
# Copy this file to .env and fill in your values

# --- RPC Endpoints (Arbitrum) ---
RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_BACKUP_1=
RPC_BACKUP_2=

# --- Contract Addresses ---
RANGEMANAGER_ADDRESS=
VAULT_ADDRESS=
TREASURY_ADDRESS=

# --- Token Addresses (Arbitrum) ---
TOKEN0_ADDRESS=0x82af49447d8a07e3bd95bd0d56f35241523fbab1
TOKEN1_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
TOKEN0_DECIMALS=18
TOKEN1_DECIMALS=6

# --- Uniswap V3 Pool ---
FEE=500

# --- Keeper Bot ---
# Private key of the keeper wallet (funded with ETH for gas)
KEEPER_PRIVATE_KEY=

# Check interval in minutes
CHECK_INTERVAL_MIN=10

# --- Multi-Swap Configuration ---
# Maximum USD amount per swap (splits large swaps into chunks)
INIT_MULTI_SWAP_TVL=10000
