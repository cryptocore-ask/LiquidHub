# =============================================================================
# Liquid Hub — GMX v2 Trading Keeper (Arbitrum)
# =============================================================================
# Copy this file to .env and fill in your values.
# This is a community keeper configuration — you only need the variables
# required to run a keeper bot that monitors SL/TP/liquidation and settles
# commissions on the TradingVault.

# --- RPC (Arbitrum) ---
# Primary RPC is required. Backups are optional but strongly recommended:
# the keeper automatically falls back to RPC_BACKUP_1, then RPC_BACKUP_2 if the
# primary fails (timeout, rate limit, network down). If all RPCs fail, the
# keeper skips the cycle to avoid acting on incomplete state.
RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_BACKUP_1=https://arb1.arbitrum.io/rpc
RPC_BACKUP_2=https://rpc.ankr.com/arbitrum

# --- Contract Address (find the latest on-chain) ---
TRADING_VAULT_ADDRESS=

# --- Keeper Wallet ---
# Private key of the keeper wallet (funded with ETH for gas).
# Keepers earn a USDC bounty from the Treasury when keeperBountyEnabled is true.
KEEPER_PRIVATE_KEY=

# --- Keeper Timing ---
# How often the keeper polls positions (in milliseconds). 30000 = 30s.
CHECK_INTERVAL_MS=30000

# --- GMX Execution Fee ---
# Native ETH amount attached when executing SL/TP/liquidation on GMX.
# 0.0002 ETH is the standard execution fee on Arbitrum.
EXECUTION_FEE=0.0002

# --- SL / TP default percentages (on collateral, adjusted for leverage) ---
# These are the percentages the keeper uses when the vault SL/TP is set to 0
# (no position-specific override). They trigger SL/TP relative to entry price.
DEFAULT_STOP_LOSS_PERCENT=4
DEFAULT_TAKE_PROFIT_PERCENT=8

# --- Ultimate Short Stop Loss (safety cap for SHORT positions) ---
# Force-closes a SHORT position when price moves up by more than N% vs entry,
# regardless of the vault SL setting. Protects against runaway upside.
ULTIM_SHORT_STOP_LOSS_ENABLED=false
ULTIM_SHORT_STOP_LOSS_PERCENT=20
