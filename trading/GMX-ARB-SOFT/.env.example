# =============================================================================
# LIQUID HUB — GMX v2 Trading Bot (Arbitrum)
# =============================================================================

# --- Network ---
NETWORK_NAME=Arbitrum
CHAIN_ID=42161

# --- RPC ---
RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_BACKUP_1=https://rpc.ankr.com/arbitrum
RPC_BACKUP_2=

# --- Deployed Contracts (fill after deployment) ---
TRADING_VAULT_ADDRESS=
TRADING_BOT_MODULE_ADDRESS=
SAFE_ADDRESS=

# --- Treasury & Commission ---
TREASURY_ADDRESS=
COMMISSION_RATE_BPS=1000              # 10% on profits

# --- Bot ---
BOT_ADDRESS=
SAFE_PRIVATE_KEY=                     # Or use AWS Secrets Manager

# --- Safe ---
SAFE_API_URL=https://safe-transaction-arbitrum.safe.global

# --- Tokens (Arbitrum) ---
USDC_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831

# --- GMX v2 (Arbitrum) ---
GMX_EXCHANGE_ROUTER=0x87d66368cD08a7Ca42252f5ab44B2fb6d1Fb8d15
GMX_ORDER_VAULT=0x31eF83a530Fde1B38EE9A18093A333D8Bbbc40D5
GMX_READER=0x5Ca84c34a381434786738735265b9f3FD814b824
GMX_DATASTORE=0xFD70de6b91282D8017aA4E741e9Ae325CAb992d8
GMX_ORACLE_URL=https://arbitrum-api.gmxinfra.io
GMX_SUBSQUID_URL=https://gmx.squids.live/gmx-synthetics-arbitrum:prod/api/graphql

# --- Keeper Bounty ---
KEEPER_BOUNTY_ENABLED=false
KEEPER_BOUNTY_AMOUNT=500000           # 0.50 USDC (6 decimals)

# --- Risk Management ---
MAX_POSITION_SIZE_PERCENT=5
MAX_TOTAL_EXPOSURE_PERCENT=30
MAX_LEVERAGE=5
DEFAULT_LEVERAGE=3
MAX_DAILY_LOSS_PERCENT=5
MAX_CONCURRENT_POSITIONS=5

# --- Stop Loss / Take Profit ---
DEFAULT_STOP_LOSS_PERCENT=3
DEFAULT_TAKE_PROFIT_PERCENT=6
TRAILING_STOP_ENABLED=true
TRAILING_STOP_ACTIVATION_PERCENT=4
TRAILING_STOP_DISTANCE_PERCENT=2

# --- Sizing ---
POSITION_SIZING_MODE=fixed_percent
FIXED_POSITION_SIZE_PERCENT=3

# --- Technical Indicators ---
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
BB_PERIOD=20
BB_STD_DEV=2
EMA_SHORT=9
EMA_LONG=21

# --- Timing ---
AI_SIGNAL_INTERVAL_MINUTES=60
INDICATOR_TIMEFRAME=4h
INDICATOR_TIMEFRAMES=1h,4h,1d

# --- Signal Weights ---
WEIGHT_TECHNICAL=0.45
WEIGHT_GROK_SENTIMENT=0.30
WEIGHT_GROK_MACRO=0.25
AI_MIN_CONVICTION_THRESHOLD=0.7

# --- Market Filters ---
MIN_24H_VOLUME_USD=500000
MIN_OPEN_INTEREST_USD=200000
EXCLUDED_MARKETS=

# --- AI ---
GROK_API_KEY=
GROK_MODEL=grok-4-1-fast-reasoning

# --- Notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Position Watcher ---
LIQUIDATION_WARN_PERCENT=15
LIQUIDATION_CRITICAL_PERCENT=5

# --- Gas ---
MAX_GAS_PRICE_GWEI=0.3
MIN_OPERATOR_ETH_BALANCE=0.05
